# ────────────────────────────────────────────
# OpenAI API  ← 이 파일을 .env로 복사 후 키 입력
# ────────────────────────────────────────────
OPENAI_API_KEY=sk-여기에_실제_키_입력

# 모델 변경 시 이 값만 수정 (기본: gpt-4o-mini)
# gpt-4o-mini  → 빠르고 저렴, 소규모 테스트에 적합
# gpt-4.1-nano → 최신 경량 모델 (2025.04 출시)
# gpt-4o       → 고성능, 정확도 우선 시 사용
# gpt-4.1      → 최신 고성능 모델
OPENAI_MODEL=gpt-4o-mini

# ────────────────────────────────────────────
# 임베딩 모델 (HuggingFace 캐시에서 로드)
# ────────────────────────────────────────────
EMBEDDING_MODEL=dragonkue/snowflake-arctic-embed-l-v2.0-ko

# ────────────────────────────────────────────
# ChromaDB
# ────────────────────────────────────────────
# CHROMA_DIR=chroma_db  ← 기본값: git root/chroma_db (config.py 자동 계산)
CHROMA_COLLECTION=snowflake_arctic_ko

# ────────────────────────────────────────────
# Django 보안
# ────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-여기에_실제_키_입력

# ────────────────────────────────────────────
# PostgreSQL DB
# ────────────────────────────────────────────
DB_NAME=pcdb
DB_USER=pc
DB_PASSWORD=비밀번호_입력
DB_HOST=localhost
DB_PORT=5433
